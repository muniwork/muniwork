---
const { organization } = Astro.props;
const totalOpenJobs = Astro.props.totalOpenJobs ?? 0;
const totalOpenBids = Astro.props.totalOpenBids ?? 0;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const sections = [
  ['Overview', `/${organization.slug}`],
  ['Careers', `/${organization.slug}/careers`],
  ['Procurement', `/${organization.slug}/procurement`],
  ['Meetings', `/${organization.slug}/meetings`],
];

const formattedOpenJobs = Number(totalOpenJobs).toLocaleString();
const formattedOpenBids = Number(totalOpenBids).toLocaleString();
---

<div class="-mb-px overflow-x-auto pb-px pt-3">
  <nav
    class="inline-flex w-fit items-center justify-center gap-1 text-sm font-medium"
    aria-label="Organization profile sections"
  >
    {sections.map(([section, href]) => {
      const isCurrent = currentPath === href;

      return (
        <a
          aria-current={isCurrent ? 'page' : undefined}
          class={`-mb-px inline-flex items-center justify-center whitespace-nowrap border-b px-4 pb-3 pt-1 transition-colors sm:px-5 ${isCurrent ? 'border-foreground text-foreground' : 'border-transparent text-muted-foreground hover:text-foreground'}`}
          href={href}
        >
          <span class="inline-flex items-center gap-1.5">
            {section}
            {section === 'Careers' && (
              <span
                class="badge min-w-5 justify-center px-1.5"
                data-variant={totalOpenJobs > 0 ? 'outline' : 'secondary'}
                aria-label={`${formattedOpenJobs} available careers`}
              >
                {formattedOpenJobs}
              </span>
            )}
            {section === 'Procurement' && (
              <span
                class="badge min-w-5 justify-center px-1.5"
                data-variant={totalOpenBids > 0 ? 'outline' : 'secondary'}
                aria-label={`${formattedOpenBids} open bids`}
              >
                {formattedOpenBids}
              </span>
            )}
          </span>
        </a>
      );
    })}
  </nav>
</div>
