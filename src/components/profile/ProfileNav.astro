---
import {
  BriefcaseBusiness,
  CalendarDays,
  FileText,
  Landmark,
  type AstroComponent,
} from '@lucide/astro';

const { organization } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const sections: [string, string, AstroComponent][] = [
  ['Overview', `/${organization.slug}`, Landmark],
  ['Careers', `/${organization.slug}/careers`, BriefcaseBusiness],
  ['Procurement', `/${organization.slug}/procurement`, FileText],
  ['Meetings', `/${organization.slug}/meetings`, CalendarDays],
];
---

<div class="tabs overflow-x-auto py-3">
  <nav
    aria-label="Organization profile sections"
    role="tablist"
    data-variant="line"
  >
    {sections.map(([section, href, Icon]) => {
      const isCurrent = currentPath === href;

      return (
        <a
          role="tab"
          aria-selected={isCurrent ? 'true' : 'false'}
          aria-current={isCurrent ? 'page' : undefined}
          href={href}
        >
          <Icon class="size-4" aria-hidden="true" />
          {section}
        </a>
      );
    })}
  </nav>
</div>
