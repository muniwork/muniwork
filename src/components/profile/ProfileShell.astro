---
import ProfileHeader from './ProfileHeader.astro';
import ProfileMapCover from './ProfileMapCover.astro';
import ProfileNav from './ProfileNav.astro';
import SiteHeader from './SiteHeader.astro';

const { organization } = Astro.props;
const totalOpenJobs = Astro.props.totalOpenJobs ?? 0;
---

<main class="min-h-screen bg-background text-foreground">
  <SiteHeader organization={organization} />

  <div class="relative overflow-hidden bg-muted/30">
    <ProfileMapCover organization={organization} />
    <div class="relative z-10 bg-background/55">
      <ProfileHeader organization={organization} />
    </div>
  </div>

  <div class="sticky top-0 z-20 border-y bg-background/95 backdrop-blur">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <ProfileNav organization={organization} totalOpenJobs={totalOpenJobs} />
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <slot />
  </div>

  <footer class="border-t px-4 py-5 text-center text-xs text-muted-foreground sm:px-6 lg:px-8">
    Maps &copy; Mapbox &copy; OpenStreetMap contributors
  </footer>
</main>
