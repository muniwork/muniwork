---
import ProfileListingSection from './ProfileListingSection.astro';
import ProfileListingTitle from './ProfileListingTitle.astro';
import type { OpenBid } from '../../lib/bids';
import { formatListingTitle, formatShortDate } from '../../lib/formatters';

const openBids = (Astro.props.openBids ?? []) as OpenBid[];
const totalOpenBids = Astro.props.totalOpenBids ?? openBids.length;
const procurementHref = Astro.props.procurementHref as string | undefined;
const showSectionDivider = Astro.props.showSectionDivider ?? true;
const visibleBidCount = openBids.length;
const hasOpenBids = visibleBidCount > 0;
const displayBids = openBids.map((bid) => ({
  ...bid,
  displayTitle: formatListingTitle(bid.title),
  closeDate: formatShortDate(bid.closeAt),
}));

---

<ProfileListingSection
  id="procurement"
  title="Procurement"
  hasItems={hasOpenBids}
  showSectionDivider={showSectionDivider}
  viewAllHref={procurementHref}
  viewAllLabel="View all procurements"
  showViewAll={totalOpenBids > visibleBidCount}
  emptyTitle="No open bids found"
  emptyBody="Muniwork does not currently have open bid opportunities for this organization."
>
  <Fragment slot="items">
    {displayBids.map((bid) => (
      <article class="grid gap-3 border-b py-4 last:border-b-0 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
        <div class="min-w-0">
          <h3 class="text-base font-semibold leading-6">
            <ProfileListingTitle title={bid.displayTitle} href={bid.publicUrl} />
          </h3>
          {(bid.bidNumber || bid.bidType) && (
            <p class="mt-1 text-sm text-muted-foreground">
              {[bid.bidType, bid.bidNumber].filter(Boolean).join(' · ')}
            </p>
          )}
        </div>
        <div class="grid gap-1 text-left text-sm text-muted-foreground sm:text-right">
          {bid.closeDate ? (
            <p>
              <span class="font-medium text-foreground">Closes</span> {bid.closeDate}
            </p>
          ) : (
            <p>
              <span class="font-medium text-foreground">Close date not listed</span>
            </p>
          )}
        </div>
      </article>
    ))}
  </Fragment>
</ProfileListingSection>
