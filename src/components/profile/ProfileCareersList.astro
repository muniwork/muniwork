---
import ProfileListingSection from './ProfileListingSection.astro';
import ProfileListingTitle from './ProfileListingTitle.astro';
import type { OpenJob } from '../../lib/jobs';
import { formatListingTitle, formatShortDate } from '../../lib/formatters';

const openJobs = (Astro.props.openJobs ?? []) as OpenJob[];
const totalOpenJobs = Astro.props.totalOpenJobs ?? openJobs.length;
const careersHref = Astro.props.careersHref as string | undefined;
const showPostedDates = Astro.props.showPostedDates ?? true;
const showSectionDivider = Astro.props.showSectionDivider ?? true;
const visibleJobCount = openJobs.length;
const hasOpenJobs = visibleJobCount > 0;
const displayJobs = openJobs.map((job) => ({
  ...job,
  displayTitle: formatListingTitle(job.title),
  postedDate: formatShortDate(job.postedAt),
  closesDate: formatShortDate(job.closesAt),
}));

---

<ProfileListingSection
  id="careers"
  title="Careers"
  hasItems={hasOpenJobs}
  showSectionDivider={showSectionDivider}
  viewAllHref={careersHref}
  viewAllLabel="View all careers"
  showViewAll={totalOpenJobs > visibleJobCount}
  emptyTitle="No open careers found"
  emptyBody="Muniwork does not currently have open public career postings for this organization."
>
  <Fragment slot="items">
    {displayJobs.map((job) => (
      <article class="grid gap-3 border-b py-4 last:border-b-0 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
        <div class="min-w-0">
          <h3 class="text-base font-semibold leading-6">
            <ProfileListingTitle title={job.displayTitle} href={job.applyUrl} />
          </h3>
          {job.department && (
            <p class="mt-1 text-sm text-muted-foreground">
              {job.department}
            </p>
          )}
        </div>
        <div class="grid gap-1 text-left text-sm text-muted-foreground sm:text-right">
          {showPostedDates && job.postedDate && (
            <p>
              <span class="font-medium text-foreground">Posted</span> {job.postedDate}
            </p>
          )}
          {job.closesDate ? (
            <p>
              <span class="font-medium text-foreground">Closes</span> {job.closesDate}
            </p>
          ) : !showPostedDates ? (
            <p>
              <span class="font-medium text-foreground">Open until filled</span>
            </p>
          ) : null}
        </div>
      </article>
    ))}
  </Fragment>
</ProfileListingSection>
