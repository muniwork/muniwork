---
import ProfileListingSection from './ProfileListingSection.astro';
import ProfileListingTitle from './ProfileListingTitle.astro';
import type { UpcomingMeeting } from '../../lib/meetings';
import { formatEasternDateTime, formatListingTitle, formatLocation } from '../../lib/formatters';

const upcomingMeetings = (Astro.props.upcomingMeetings ?? []) as UpcomingMeeting[];
const totalUpcomingMeetings = Astro.props.totalUpcomingMeetings ?? upcomingMeetings.length;
const meetingsHref = Astro.props.meetingsHref as string | undefined;
const showSectionDivider = Astro.props.showSectionDivider ?? true;
const visibleMeetingCount = upcomingMeetings.length;
const hasUpcomingMeetings = visibleMeetingCount > 0;
const displayMeetings = upcomingMeetings.map((meeting) => ({
  ...meeting,
  displayTitle: formatListingTitle(meeting.title),
  displayLocation: formatLocation(meeting.location),
  startsAtText: formatEasternDateTime(meeting.startsAt),
}));
---

<ProfileListingSection
  id="meetings"
  title="Upcoming meetings"
  hasItems={hasUpcomingMeetings}
  showSectionDivider={showSectionDivider}
  viewAllHref={meetingsHref}
  viewAllLabel="View all meetings"
  showViewAll={totalUpcomingMeetings > visibleMeetingCount}
  emptyTitle="No upcoming meetings found"
  emptyBody="Muniwork does not currently have upcoming public meetings for this organization."
>
  <Fragment slot="items">
    {displayMeetings.map((meeting) => (
      <article class="grid gap-3 border-b py-4 last:border-b-0 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
        <div class="min-w-0">
          <h3 class="text-base font-semibold leading-6">
            <ProfileListingTitle title={meeting.displayTitle} href={meeting.publicUrl} />
          </h3>
          {meeting.displayLocation && (
            <p class="mt-1 text-sm text-muted-foreground">
              {meeting.displayLocation}
            </p>
          )}
        </div>
        <div class="grid gap-1 text-left text-sm text-muted-foreground sm:text-right">
          {meeting.startsAtText && <p>{meeting.startsAtText}</p>}
        </div>
      </article>
    ))}
  </Fragment>
</ProfileListingSection>
