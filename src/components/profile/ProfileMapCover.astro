---
import { getMapboxStaticAccessToken } from '../../lib/mapbox.js';

const { organization } = Astro.props;

const DEFAULT_ZOOM = 10;
const MAPBOX_STYLE = 'mapbox/light-v11';
const MAP_IMAGE_SIZE = '1280x240@2x';

const lat = Number(organization.coverLat);
const lng = Number(organization.coverLng);
const zoom = Number.isFinite(Number(organization.coverZoom))
  ? Number(organization.coverZoom)
  : DEFAULT_ZOOM;
const hasCoordinates = Number.isFinite(lat) && Number.isFinite(lng);
const mapboxToken = getMapboxStaticAccessToken();

let mapUrl = null;

if (hasCoordinates && mapboxToken) {
  const params = new URLSearchParams({
    access_token: mapboxToken,
    attribution: 'false',
    logo: 'false',
  });
  const position = `${lng.toFixed(5)},${lat.toFixed(5)},${zoom},0`;

  mapUrl = `https://api.mapbox.com/styles/v1/${MAPBOX_STYLE}/static/${position}/${MAP_IMAGE_SIZE}?${params.toString()}`;
}

const label = organization.coverLocationLabel || organization.officialName;
---

<section
  aria-label={hasCoordinates ? `Map cover for ${label}` : 'Map cover unavailable'}
  class="h-28 overflow-hidden border-b bg-muted sm:h-36"
>
  {mapUrl ? (
    <img
      alt=""
      class="h-full w-full object-cover opacity-80"
      decoding="async"
      loading="eager"
      src={mapUrl}
    />
  ) : (
    <div class="h-full w-full bg-muted"></div>
  )}
</section>
