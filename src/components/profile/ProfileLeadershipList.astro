---
import { ArrowUpRight } from '@lucide/astro';
import type { LeadershipRole } from '../../lib/leadership';

const leadership = (Astro.props.leadership ?? []) as LeadershipRole[];
const hasLeadership = leadership.length > 0;
const governingBodyRoles = leadership.filter((role) =>
  /mayor|commissioner|council/i.test(role.title)
);
const administrationRoles = leadership.filter(
  (role) => !governingBodyRoles.includes(role)
);
const hasSingleAdministrationRole = administrationRoles.length === 1;
---

<section id="leadership" class="scroll-mt-24">
  <article class="border-b pb-8">
    <header class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <h2 class="text-xl font-semibold">Leadership</h2>
    </header>

    <section class="mt-4">
      {hasLeadership ? (
        <div class="grid gap-6">
          {governingBodyRoles.length > 0 && (
            <div>
              <div class="grid gap-2 sm:grid-cols-3 lg:grid-cols-5 xl:grid-cols-7">
                {governingBodyRoles.map((role) => {
                  const href = role.url || role.sourceUrl;

                  return (
                    <article class="grid min-h-24 gap-2 rounded-md border bg-background p-3 shadow-sm">
                      <div class="min-w-0">
                        <h3 class="text-sm font-semibold leading-5">
                          {href ? (
                            <a
                              class="external-link underline-offset-4 hover:text-foreground hover:underline"
                              href={href}
                              rel="noreferrer"
                              target="_blank"
                            >
                              <span>{role.name}</span>
                              <ArrowUpRight aria-hidden="true" class="external-link__icon" />
                            </a>
                          ) : (
                            role.name
                          )}
                        </h3>
                        <p class="mt-1 text-xs leading-4 text-muted-foreground">{role.title}</p>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          )}

          {governingBodyRoles.length > 0 && administrationRoles.length > 0 && (
            <div class="flex justify-center" aria-hidden="true">
              <div class="h-8 border-l"></div>
            </div>
          )}

          {administrationRoles.length > 0 && (
            <div>
              <div class="grid gap-2 sm:grid-cols-3 lg:grid-cols-5">
                {administrationRoles.map((role) => {
                  const href = role.url || role.sourceUrl;
                  const cardClass = [
                    'grid min-h-24 gap-2 rounded-md border bg-background p-3 shadow-sm',
                    hasSingleAdministrationRole ? 'sm:col-start-2 lg:col-start-3' : '',
                  ]
                    .filter(Boolean)
                    .join(' ');

                  return (
                    <article class={cardClass}>
                      <div class="min-w-0">
                        <h3 class="text-sm font-semibold leading-5">
                          {href ? (
                            <a
                              class="external-link underline-offset-4 hover:text-foreground hover:underline"
                              href={href}
                              rel="noreferrer"
                              target="_blank"
                            >
                              <span>{role.name}</span>
                              <ArrowUpRight aria-hidden="true" class="external-link__icon" />
                            </a>
                          ) : (
                            role.name
                          )}
                        </h3>
                        <p class="mt-1 text-xs leading-4 text-muted-foreground">{role.title}</p>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class="alert">
          <div>
            <strong>No leadership records found</strong>
            <p>Muniwork does not currently have source-backed leadership records for this organization.</p>
          </div>
        </div>
      )}
    </section>
  </article>
</section>
