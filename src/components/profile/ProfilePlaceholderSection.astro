---
const { title, label, body, metrics = [] } = Astro.props;
const typedMetrics = metrics as [string, string][];
---

<section class="scroll-mt-24">
  <article class="card">
    <header class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-medium text-muted-foreground">{label}</p>
        <h2 class="text-2xl font-semibold">{title}</h2>
      </div>
      <p class="badge" data-variant="outline">Not loaded</p>
    </header>
    <section class="grid gap-5">
      <p class="leading-7 text-muted-foreground">{body}</p>
      {typedMetrics.length > 0 && (
        <dl class="grid gap-3 sm:grid-cols-2">
          {typedMetrics.map(([metricLabel, value]) => (
            <div>
              <dt class="text-xs font-medium uppercase text-muted-foreground">
                {metricLabel}
              </dt>
              <dd class="mt-2 text-base font-semibold">{value}</dd>
            </div>
          ))}
        </dl>
      )}
    </section>
  </article>
</section>
