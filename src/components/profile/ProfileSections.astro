---
const { organization } = Astro.props;

type OpenJob = {
  id: string;
  title: string;
  department?: string | null;
  location?: string | null;
  employmentType?: string | null;
  postedAt?: string | null;
  closesAt?: string | null;
  applyUrl?: string | null;
  status: string;
  firstSeenAt?: string | null;
  lastSeenAt?: string | null;
};

const openJobs = (Astro.props.openJobs ?? []) as OpenJob[];
const totalOpenJobs = Astro.props.totalOpenJobs ?? openJobs.length;
const visibleJobCount = openJobs.length;
const hasOpenJobs = visibleJobCount > 0;

function findLatestSeenAt(jobs: OpenJob[]): string | null {
  return jobs.reduce<string | null>((latest, job) => {
    if (!job.lastSeenAt) {
      return latest;
    }

    if (!latest || new Date(job.lastSeenAt) > new Date(latest)) {
      return job.lastSeenAt;
    }

    return latest;
  }, null);
}

const latestSeenAt = findLatestSeenAt(openJobs);

function formatDate(value: string | null | undefined): string | null {
  if (!value) {
    return null;
  }

  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(value));
}

function formatOpenJobsSummary() {
  if (totalOpenJobs === 0) {
    return 'No open jobs';
  }

  if (totalOpenJobs > visibleJobCount) {
    return `${visibleJobCount} of ${totalOpenJobs} open jobs`;
  }

  return `${totalOpenJobs} open ${totalOpenJobs === 1 ? 'job' : 'jobs'}`;
}

const facts = [
  ['Organization type', organization.organizationType],
  ['State', organization.stateCode],
  ['Profile slug', organization.slug],
  ['Website', organization.officialWebsite ? 'Available' : 'Not listed'],
];

const pipelineSections = [
  {
    id: 'procurement',
    title: 'Procurement',
    label: 'Purchasing',
    body:
      'Bid notices, purchasing links, contract opportunities, and vendor-facing documents for this organization.',
    metrics: [
      ['Open bids', 'Not loaded'],
      ['Source status', 'Unconnected'],
    ],
  },
  {
    id: 'meetings',
    title: 'Meetings',
    label: 'Public records',
    body:
      'Meeting calendars, agendas, minutes, and recent public decisions for this organization.',
    metrics: [
      ['Upcoming meetings', 'Not loaded'],
      ['Recent records', 'Unconnected'],
    ],
  },
];
---

<div class="grid gap-10">
  <section id="overview" class="scroll-mt-24">
    <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-medium text-muted-foreground">Profile</p>
        <h2 class="text-2xl font-semibold">Overview</h2>
      </div>
      <p class="text-sm text-muted-foreground">
        Source-backed facts for this organization.
      </p>
    </div>

    <div class="grid items-start gap-4 lg:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.65fr)]">
      <article class="card">
        <header>
          <h3 class="text-xl font-semibold">Organization summary</h3>
        </header>
        <section>
          <p class="leading-7 text-muted-foreground">
            {organization.officialName} is a {organization.organizationType} profile
            in {organization.stateCode}. This page is organized around the core
            public-sector workflows Muniwork will track for each organization:
            jobs, procurement, and meetings.
          </p>
        </section>
      </article>

      <dl class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
        {facts.map(([label, value]) => (
          <div class="card" data-size="sm">
            <section>
              <dt class="text-xs font-medium uppercase text-muted-foreground">
                {label}
              </dt>
              <dd class="mt-2 text-base font-semibold">{value}</dd>
            </section>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section id="careers" class="scroll-mt-24">
    <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-medium text-muted-foreground">Hiring</p>
        <h2 class="text-2xl font-semibold">Careers</h2>
      </div>
      <p class="badge" data-variant={hasOpenJobs ? 'outline' : 'secondary'}>
        {formatOpenJobsSummary()}
      </p>
    </div>

    <div class="grid items-start gap-4 lg:grid-cols-[minmax(0,1.45fr)_minmax(300px,0.55fr)]">
      <article class="card">
        <header class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h3 class="text-xl font-semibold">Open roles</h3>
            <p class="text-sm text-muted-foreground">
              Public job postings for this organization.
            </p>
          </div>
          <p class="badge" data-variant="outline">{visibleJobCount} loaded</p>
        </header>
        <section>
          {hasOpenJobs ? (
            <div class="grid divide-y">
              {openJobs.map((job) => (
                <article class="grid gap-3 py-4 first:pt-0 last:pb-0 sm:grid-cols-[minmax(0,1fr)_auto]">
                  <div class="min-w-0">
                    <h4 class="text-base font-semibold leading-6">
                      {job.applyUrl ? (
                        <a
                          class="underline-offset-4 hover:underline"
                          href={job.applyUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          {job.title}
                        </a>
                      ) : (
                        job.title
                      )}
                    </h4>
                    <p class="mt-1 text-sm text-muted-foreground">
                      {[job.department, job.location].filter(Boolean).join(' / ')}
                    </p>
                  </div>
                  <div class="grid gap-1 text-left text-sm text-muted-foreground sm:text-right">
                    {formatDate(job.postedAt) && (
                      <p>
                        <span class="font-medium text-foreground">Posted</span>{' '}
                        {formatDate(job.postedAt)}
                      </p>
                    )}
                    {formatDate(job.closesAt) && (
                      <p>
                        <span class="font-medium text-foreground">Closes</span>{' '}
                        {formatDate(job.closesAt)}
                      </p>
                    )}
                  </div>
                </article>
              ))}
              {totalOpenJobs > visibleJobCount && (
                <p class="pt-4 text-sm text-muted-foreground">
                  Showing the most recent {visibleJobCount} open jobs.
                </p>
              )}
            </div>
          ) : (
            <div class="alert">
              <div>
                <strong>No open jobs found</strong>
                <p>
                  Muniwork does not currently have open public job postings for
                  this organization.
                </p>
              </div>
            </div>
          )}
        </section>
      </article>

      <div class="grid gap-3">
        <article class="card" data-size="sm">
          <section>
            <p class="text-xs font-medium uppercase text-muted-foreground">Open roles</p>
            <p class="mt-2 text-2xl font-semibold">{totalOpenJobs}</p>
          </section>
        </article>
        <article class="card" data-size="sm">
          <section>
            <p class="text-xs font-medium uppercase text-muted-foreground">Loaded roles</p>
            <p class="mt-2 text-2xl font-semibold">{visibleJobCount}</p>
          </section>
        </article>
        <article class="card" data-size="sm">
          <section>
            <p class="text-xs font-medium uppercase text-muted-foreground">Last refresh</p>
            <p class="mt-2 text-base font-semibold">{formatDate(latestSeenAt) ?? 'Not available'}</p>
          </section>
        </article>
      </div>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    {pipelineSections.map((section) => (
      <article id={section.id} class="card scroll-mt-24">
        <header class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="text-sm font-medium text-muted-foreground">{section.label}</p>
            <h2 class="text-2xl font-semibold">{section.title}</h2>
          </div>
          <p class="badge" data-variant="outline">Not loaded</p>
        </header>
        <section class="grid gap-5">
          <p class="leading-7 text-muted-foreground">{section.body}</p>
          <dl class="grid gap-3 sm:grid-cols-2">
            {section.metrics.map(([label, value]) => (
              <div>
                <dt class="text-xs font-medium uppercase text-muted-foreground">
                  {label}
                </dt>
                <dd class="mt-2 text-base font-semibold">{value}</dd>
              </div>
            ))}
          </dl>
        </section>
      </article>
    ))}
  </section>
</div>
