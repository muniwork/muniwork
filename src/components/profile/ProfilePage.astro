---
import ProfileHeader from './ProfileHeader.astro';
import ProfileMapCover from './ProfileMapCover.astro';
import ProfileSections from './ProfileSections.astro';

type OpenJob = {
  id: string;
  title: string;
  department?: string | null;
  location?: string | null;
  employmentType?: string | null;
  postedAt?: string | null;
  closesAt?: string | null;
  applyUrl?: string | null;
  status: string;
  firstSeenAt?: string | null;
  lastSeenAt?: string | null;
};

const { organization } = Astro.props;
const openJobs = (Astro.props.openJobs ?? []) as OpenJob[];
const totalOpenJobs = Astro.props.totalOpenJobs ?? openJobs.length;

const sections = ['Overview', 'Careers', 'Procurement', 'Meetings'];
---

<main class="min-h-screen bg-background text-foreground">
  <div class="relative overflow-hidden border-b bg-muted/30">
    <ProfileMapCover organization={organization} />
    <div class="relative z-10 bg-background/55">
      <ProfileHeader organization={organization} />
    </div>
  </div>

  <div class="sticky top-0 z-10 border-b bg-background/95">
    <nav
      aria-label="Organization profile sections"
      class="mx-auto flex max-w-7xl gap-2 overflow-x-auto px-4 py-3 sm:px-6 lg:px-8"
    >
      {sections.map((section) => (
        <a
          class="btn shrink-0"
          data-size="sm"
          data-variant="ghost"
          href={`#${section.toLowerCase()}`}
        >
          {section}
        </a>
      ))}
    </nav>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <ProfileSections
      organization={organization}
      openJobs={openJobs}
      totalOpenJobs={totalOpenJobs}
    />
  </div>

  <footer class="border-t px-4 py-5 text-center text-xs text-muted-foreground sm:px-6 lg:px-8">
    Maps &copy; Mapbox &copy; OpenStreetMap contributors
  </footer>
</main>
