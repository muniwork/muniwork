---
import ProfileHeader from './ProfileHeader.astro';
import ProfileMeta from './ProfileMeta.astro';
import ProfileSections from './ProfileSections.astro';

const { organization } = Astro.props;
---

<main class="min-h-screen bg-muted/30 px-4 py-12 text-foreground sm:px-5 sm:py-16">
  <div class="mx-auto grid max-w-5xl gap-6">
    <ProfileHeader organization={organization} />
    <ProfileMeta organization={organization} />
    <ProfileSections organization={organization} />
  </div>
</main>
