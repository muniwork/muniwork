---
import ProfileHeader from './ProfileHeader.astro';
import ProfileMeta from './ProfileMeta.astro';
import ProfileSections from './ProfileSections.astro';

const { organization } = Astro.props;
---

<main class="page">
  <div class="shell">
    <ProfileHeader organization={organization} />
    <ProfileMeta organization={organization} />
    <ProfileSections organization={organization} />
  </div>
</main>

<style>
  :global(html) {
    background: #f4f1eb;
    color: #1c1b18;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
      sans-serif;
  }

  .page {
    min-height: 100vh;
    padding: 48px 20px 72px;
  }

  .shell {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    gap: 24px;
  }

  .profile-header {
    padding: 32px;
    border-radius: 28px;
    background: linear-gradient(135deg, #ffffff 0%, #f7efe2 100%);
    border: 1px solid rgba(28, 27, 24, 0.08);
    box-shadow: 0 16px 40px rgba(28, 27, 24, 0.08);
  }

  .eyebrow {
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    color: #7f6b53;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .subtitle,
  .website {
    margin: 12px 0 0;
    font-size: 1rem;
    color: #5a564f;
  }

  .website a {
    color: inherit;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .profile-meta,
  .profile-sections {
    display: grid;
    gap: 16px;
  }

  .profile-meta {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .meta-item,
  .card {
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(28, 27, 24, 0.08);
    padding: 20px;
    backdrop-filter: blur(10px);
  }

  dt {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #7f6b53;
  }

  dd {
    margin: 8px 0 0;
    font-size: 1.05rem;
    font-weight: 600;
  }

  h2 {
    margin: 0 0 10px;
    font-size: 1.1rem;
  }

  p {
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .page {
      padding-inline: 14px;
    }

    .profile-header {
      padding: 24px;
      border-radius: 22px;
    }
  }
</style>

