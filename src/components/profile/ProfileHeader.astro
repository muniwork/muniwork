---
const { organization } = Astro.props;

const typeLabel =
  organization.organizationType === 'county'
    ? 'County profile'
    : 'Municipality profile';
---

<header class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-4xl">
      <p class="badge" data-variant="outline">{typeLabel}</p>
      <h1 class="mt-4 text-3xl font-semibold leading-tight sm:text-5xl">
        {organization.officialName}
      </h1>
      <p class="mt-3 text-sm text-muted-foreground sm:text-base">
        {organization.stateCode} / {organization.slug}
      </p>
    </div>

    {organization.officialWebsite && (
      <a
        class="btn w-fit"
        data-variant="outline"
        href={organization.officialWebsite}
        rel="noreferrer"
        target="_blank"
      >
        Official website
      </a>
    )}
  </div>
</header>
