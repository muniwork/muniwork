---
const { organization } = Astro.props;

const typeLabel =
  organization.organizationType === 'county'
    ? 'County profile'
    : 'Municipality profile';
---

<header class="card">
  <header>
    <p class="badge" data-variant="outline">{typeLabel}</p>
    <h1 class="mt-3 text-4xl font-semibold leading-none sm:text-6xl lg:text-7xl">
      {organization.officialName}
    </h1>
    <p class="mt-3 text-base text-muted-foreground">
      {organization.stateCode} · {organization.slug}
    </p>
  </header>
  {organization.officialWebsite && (
    <footer>
      <a
        class="btn px-0"
        data-variant="link"
        href={organization.officialWebsite}
        rel="noreferrer"
        target="_blank"
      >
        Official website
      </a>
    </footer>
  )}
</header>
