---
import { Image } from 'astro:assets';
import { Landmark } from '@lucide/astro';

const { organization } = Astro.props;
const sealAsset = organization.sealAsset;
---

<header class="mx-auto max-w-7xl px-4 py-5 sm:px-6 sm:py-7 lg:px-8">
  <div class="flex items-center gap-4">
    <div
      class="grid size-14 shrink-0 place-items-center rounded-lg border bg-background text-xl font-semibold shadow-sm sm:size-[4.5rem] sm:text-2xl"
      aria-hidden={sealAsset ? undefined : 'true'}
    >
      {
        sealAsset ? (
          <Image
            src={sealAsset.publicUrl}
            alt={`${organization.officialName} seal`}
            width={64}
            height={64}
            class="size-11 object-contain sm:size-14"
            loading="eager"
            decoding="async"
          />
        ) : (
          <Landmark class="size-7 sm:size-8" />
        )
      }
    </div>
    <div class="min-w-0">
      <h1 class="text-3xl font-semibold leading-tight sm:text-4xl">
        {organization.officialName}
      </h1>
    </div>
  </div>
</header>
