---
import { Building2, Search } from '@lucide/astro';

const { organization } = Astro.props;
const navItems = ['Platform', 'Coverage', 'Data'];
const profileHref = `/${organization.slug}`;
---

<header class="border-b bg-background">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-6 px-4 sm:px-6 lg:px-8">
    <a class="flex items-center gap-3 font-semibold" href={profileHref}>
      <span
        class="grid size-9 place-items-center rounded border text-sm font-semibold"
        aria-hidden="true"
      >
        <Building2 class="size-5" />
      </span>
      <span>Muniwork</span>
    </a>

    <nav class="hidden items-center gap-8 text-sm font-medium text-muted-foreground md:flex">
      {navItems.map((item) => (
        <a class="hover:text-foreground" href={profileHref}>
          {item}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        class="hidden text-sm font-medium text-muted-foreground hover:text-foreground sm:inline"
        href={profileHref}
      >
        Log in
      </a>
      <a class="btn gap-2" data-variant="outline" href={profileHref}>
        <Search class="size-4" aria-hidden="true" />
        Search
      </a>
    </div>
  </div>
</header>
