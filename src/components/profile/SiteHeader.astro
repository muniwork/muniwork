---
import { Search } from '@lucide/astro';

const { organization } = Astro.props;
const profileHref = `/${organization.slug}`;
---

<header class="border-b bg-background">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-6 px-4 sm:px-6 lg:px-8">
    <a class="flex items-center gap-3 font-semibold" href="/">
      <span
        class="grid size-9 place-items-center rounded-full border bg-background text-foreground shadow-sm"
        aria-hidden="true"
      >
        <svg
          class="size-6"
          viewBox="0 0 40 40"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M6 28V18C6 14.2 9.1 11 13 11C16.9 11 20 14.2 20 18V28M20 28V18C20 14.2 23.1 11 27 11C30.9 11 34 14.2 34 18V28"
            stroke="currentColor"
            stroke-width="6"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span>muniwork</span>
    </a>

    <div class="flex items-center gap-3">
      <a
        class="hidden text-sm font-medium text-muted-foreground hover:text-foreground sm:inline"
        href={profileHref}
      >
        Log in
      </a>
      <a class="btn gap-2" data-variant="outline" href={profileHref}>
        <Search class="size-4" aria-hidden="true" />
        Search
      </a>
    </div>
  </div>
</header>
