---
import { ExternalLink } from '@lucide/astro';

const { organization } = Astro.props;

const governanceIntroBySlug: Record<string, string> = {
  'boca-raton-fl':
    'Boca Raton is governed by a five-member City Council, including a directly elected mayor. Council members are elected at large to designated seats in nonpartisan elections, with staggered three-year terms and consecutive-term limits.',
};

const overviewIntro =
  governanceIntroBySlug[organization.slug] ??
  `${organization.officialName} is a ${organization.organizationType} profile in ${organization.stateCode}. This page is organized around the core public-sector workflows Muniwork will track for each organization: jobs, procurement, and meetings.`;

function formatOrganizationType(value: string | null | undefined): string {
  if (!value) {
    return 'Organization';
  }

  return value
    .split(/[\s_-]+/)
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const overviewDetails = [
  ['Type', formatOrganizationType(organization.organizationType)],
  ['State', organization.stateCode],
  organization.officialWebsite
    ? ['Website', 'Official website', organization.officialWebsite]
    : null,
].filter(Boolean);
---

<section
  id="overview"
  class="scroll-mt-24"
  aria-labelledby="overview-title"
>
  <article class="card">
    <header>
      <h2 id="overview-title" class="text-2xl font-semibold">Overview</h2>
    </header>

    <section>
      <p class="text-lg leading-8 text-muted-foreground">
        {overviewIntro}
      </p>

      <dl class="mt-8 grid gap-6 border-t pt-6 sm:grid-cols-3">
        {
          overviewDetails.map((detail) => {
            const [label, value, href] = detail as [string, string, string?];

            return (
              <div>
                <dt class="text-sm font-semibold">{label}</dt>
                <dd class="mt-2 text-sm text-muted-foreground">
                  {href ? (
                    <a
                      class="underline-offset-4 hover:text-foreground hover:underline"
                      href={href}
                      rel="noreferrer"
                      target="_blank"
                    >
                      {value}
                      <ExternalLink class="ml-1 inline size-3.5 align-[-2px]" aria-hidden="true" />
                    </a>
                  ) : (
                    value
                  )}
                </dd>
              </div>
            );
          })
        }
      </dl>
    </section>
  </article>
</section>
