---
const { organization } = Astro.props;

const facts = [
  ['Organization type', organization.organizationType],
  ['State', organization.stateCode],
  ['Profile slug', organization.slug],
  ['Website', organization.officialWebsite ? 'Available' : 'Not listed'],
];
---

<section id="overview" class="scroll-mt-24">
  <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium text-muted-foreground">Profile</p>
      <h2 class="text-2xl font-semibold">Overview</h2>
    </div>
    <p class="text-sm text-muted-foreground">
      Source-backed facts for this organization.
    </p>
  </div>

  <div class="grid items-start gap-4 lg:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.65fr)]">
    <article class="card">
      <header>
        <h3 class="text-xl font-semibold">Organization summary</h3>
      </header>
      <section>
        <p class="leading-7 text-muted-foreground">
          {organization.officialName} is a {organization.organizationType} profile
          in {organization.stateCode}. This page is organized around the core
          public-sector workflows Muniwork will track for each organization:
          jobs, procurement, and meetings.
        </p>
      </section>
    </article>

    <dl class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
      {facts.map(([label, value]) => (
        <div class="card" data-size="sm">
          <section>
            <dt class="text-xs font-medium uppercase text-muted-foreground">
              {label}
            </dt>
            <dd class="mt-2 text-base font-semibold">{value}</dd>
          </section>
        </div>
      ))}
    </dl>
  </div>
</section>
