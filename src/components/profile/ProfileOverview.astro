---
import { ArrowUpRight } from '@lucide/astro';
import { formatCountyName, formatStateName, formatWebsiteHost } from '../../lib/formatters';

const { organization } = Astro.props;
const stateName = formatStateName(organization.stateCode);
const isCounty = organization.organizationType?.trim().toLowerCase() === 'county';

const fallbackMissionStatementBySlug: Record<string, string> = {
  'boca-raton-fl':
    'Our mission is to responsibly provide outstanding services to enhance our unique quality of life.',
};

const missionStatement =
  organization.profileStatements?.mission?.statementText ??
  fallbackMissionStatementBySlug[organization.slug];

type ProfileOverviewOrganization = {
  officialName?: string | null;
  organizationType?: string | null;
};

function formatMissionSubject(organization: ProfileOverviewOrganization): string {
  const name = organization.officialName?.trim();
  const type = organization.organizationType?.trim().toLowerCase();

  if (!name) {
    return 'The organization';
  }

  if (/^(city|town|village)\s+of\s+/i.test(name)) {
    const formattedName = name.replace(/^(city|town|village)\b/i, (match: string) =>
      match.charAt(0).toUpperCase() + match.slice(1).toLowerCase()
    );

    return `The ${formattedName}`;
  }

  if (/^county\s+of\s+/i.test(name)) {
    const formattedName = name.replace(/^county\b/i, 'County');

    return `The ${formattedName}`;
  }

  if (/county$/i.test(name)) {
    return name;
  }

  if (type === 'county') {
    return `${name} County`;
  }

  return `The City of ${name}`;
}

function formatMissionClause(statement: string): string {
  const trimmedStatement = statement.trim().replace(/\s+/g, ' ').replace(/[.。]\s*$/, '');

  return trimmedStatement
    .replace(/^we are dedicated to providing\b/i, 'to provide')
    .replace(/^we are dedicated to\b/i, 'to')
    .replace(/^our mission is to\b/i, 'to')
    .replace(/^the mission is to\b/i, 'to')
    .replace(/\bour\b/gi, 'its');
}

function formatMissionIntro(
  organization: ProfileOverviewOrganization,
  statement: string
): string {
  return `${formatMissionSubject(organization)}'s mission is ${formatMissionClause(statement)}.`;
}

const overviewIntro = missionStatement
  ? formatMissionIntro(organization, missionStatement)
  : `${organization.officialName} is a ${organization.organizationType} profile in ${stateName}, organized around careers, procurement, and meetings.`;

function formatOrganizationType(value: string | null | undefined): string {
  if (!value) {
    return 'Organization';
  }

  return value
    .split(/[\s_-]+/)
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const overviewDetails = [
  ['Type', formatOrganizationType(organization.organizationType)],
  !isCounty && organization.countyName ? ['County', formatCountyName(organization.countyName)] : null,
  ['State', stateName],
  organization.officialWebsite
    ? ['Website', formatWebsiteHost(organization.officialWebsite), organization.officialWebsite]
    : null,
].filter(Boolean);
const overviewDetailsGridClass =
  overviewDetails.length >= 4 ? 'sm:grid-cols-4' : 'sm:grid-cols-3';
---

<section
  id="overview"
  class="scroll-mt-24"
  aria-labelledby="overview-title"
>
  <article class="border-b pb-8">
    <h2 id="overview-title" class="sr-only">Overview</h2>

    <p class="max-w-5xl text-sm leading-5 text-muted-foreground">
      {overviewIntro}
    </p>

    <dl class={`mt-7 grid gap-x-10 gap-y-6 ${overviewDetailsGridClass}`}>
      {
        overviewDetails.map((detail) => {
          const [label, value, href] = detail as [string, string, string?];

          return (
            <div>
              <dt class="text-sm font-semibold">{label}</dt>
              <dd class="mt-2 text-sm text-muted-foreground">
                {href ? (
                  <a
                    class="external-link underline-offset-4 hover:text-foreground hover:underline"
                    href={href}
                    rel="noreferrer"
                    target="_blank"
                  >
                    <span>{value}</span>
                    <ArrowUpRight aria-hidden="true" class="external-link__icon" />
                  </a>
                ) : (
                  value
                )}
              </dd>
            </div>
          );
        })
      }
    </dl>
  </article>
</section>
