---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileNotFound from '../../components/profile/ProfileNotFound.astro';
import ProfileProcurementList from '../../components/profile/ProfileProcurementList.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import SupabaseSetupNotice from '../../components/system/SupabaseSetupNotice.astro';
import { getProfileRouteStatus, loadProfileRouteData } from '../../lib/profile-route';
import { getCanonicalUrl } from '../../lib/site';
import '../../styles/global.css';

const { slug } = Astro.params;
const routeData = await loadProfileRouteData(slug, { bidLimit: 100, jobLimit: 1 });
const { profile, missingSupabaseVariables } = routeData;
const { organization, openBids, totalOpenBids, totalOpenJobs } = profile;
const routeStatus = getProfileRouteStatus(routeData);

if (routeStatus) {
  Astro.response.status = routeStatus;
}

const pageTitle = organization
  ? `${organization.officialName} procurement | Muniwork`
  : missingSupabaseVariables.length > 0
    ? 'Muniwork setup required'
    : 'Organization procurement not found | Muniwork';
const pageDescription = organization
  ? `Open bid opportunities and procurement notices for ${organization.officialName}.`
  : 'Muniwork profiles local government organizations and public-sector procurement opportunities.';
const canonicalUrl = organization
  ? getCanonicalUrl(Astro.url, `/${organization.slug}/procurement`)
  : getCanonicalUrl(Astro.url);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  image={organization?.sealAsset?.publicUrl}
>
  {missingSupabaseVariables.length > 0 ? (
    <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
  ) : organization ? (
    <ProfileShell
      organization={organization}
      totalOpenJobs={totalOpenJobs}
      totalOpenBids={totalOpenBids}
    >
      <ProfileProcurementList
        openBids={openBids}
        totalOpenBids={totalOpenBids}
        showSectionDivider={false}
      />
    </ProfileShell>
  ) : (
    <ProfileNotFound />
  )}
</BaseLayout>
