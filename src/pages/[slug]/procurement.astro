---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileProcurementList from '../../components/profile/ProfileProcurementList.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import SupabaseSetupNotice from '../../components/system/SupabaseSetupNotice.astro';
import type { OpenBid } from '../../lib/bids';
import { getOrganizationProfileBySlug } from '../../lib/profile';
import { MissingSupabaseEnvError } from '../../lib/supabase.js';
import '../../styles/global.css';

const { slug } = Astro.params;
let organization = null;
let openBids: OpenBid[] = [];
let totalOpenBids = 0;
let totalOpenJobs = 0;
let missingSupabaseVariables = [];

try {
  const profile = await getOrganizationProfileBySlug(slug, { bidLimit: 100, jobLimit: 1 });
  organization = profile.organization;
  openBids = profile.openBids;
  totalOpenBids = profile.totalOpenBids;
  totalOpenJobs = profile.totalOpenJobs;
} catch (error) {
  if (!(error instanceof MissingSupabaseEnvError)) {
    throw error;
  }

  missingSupabaseVariables = error.missingVariables;
}

if (missingSupabaseVariables.length > 0) {
  Astro.response.status = 503;
} else if (!organization) {
  Astro.response.status = 404;
}

const pageTitle = organization
  ? `${organization.officialName} procurement | Muniwork`
  : missingSupabaseVariables.length > 0
    ? 'Muniwork setup required'
    : 'Organization procurement not found | Muniwork';
const pageDescription = organization
  ? `Open bid opportunities and procurement notices for ${organization.officialName}.`
  : 'Muniwork profiles local government organizations and public-sector procurement opportunities.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {missingSupabaseVariables.length > 0 ? (
    <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
  ) : organization ? (
    <ProfileShell
      organization={organization}
      totalOpenJobs={totalOpenJobs}
      totalOpenBids={totalOpenBids}
    >
      <ProfileProcurementList
        openBids={openBids}
        totalOpenBids={totalOpenBids}
        showSectionDivider={false}
      />
    </ProfileShell>
  ) : (
    <main class="min-h-screen bg-muted/30 px-5 py-12 text-foreground">
      <div class="mx-auto max-w-3xl">
        <p class="badge" data-variant="outline">
          Not found
        </p>
        <h1 class="mt-3 text-4xl font-semibold leading-none sm:text-5xl">
          Organization not found
        </h1>
        <p class="mt-3 leading-7 text-muted-foreground">
          There is no organization profile for this slug.
        </p>
      </div>
    </main>
  )}
</BaseLayout>
