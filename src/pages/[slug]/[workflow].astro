---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileNotFound from '../../components/profile/ProfileNotFound.astro';
import ProfilePlaceholderSection from '../../components/profile/ProfilePlaceholderSection.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import SupabaseSetupNotice from '../../components/system/SupabaseSetupNotice.astro';
import { getProfileRouteStatus, loadProfileRouteData } from '../../lib/profile-route';
import { profileWorkflowSections } from '../../lib/profile-sections.js';
import { getCanonicalUrl } from '../../lib/site';
import '../../styles/global.css';

type WorkflowSection = {
  title: string;
  label: string;
  body: string;
  metrics: string[][];
};

const { slug, workflow } = Astro.params;
const workflowSections = profileWorkflowSections as Record<string, WorkflowSection>;
const section = workflow ? workflowSections[workflow] : null;
const routeData = await loadProfileRouteData(
  slug,
  { bidLimit: 1, jobLimit: 1 },
  { shouldLoad: Boolean(section) }
);
const { profile, missingSupabaseVariables } = routeData;
const { organization, totalOpenJobs, totalOpenBids } = profile;
const routeStatus = getProfileRouteStatus(routeData, { notFound: !section || !organization });

if (routeStatus) {
  Astro.response.status = routeStatus;
}

const pageTitle = organization && section
  ? `${section.title} for ${organization.officialName} | Muniwork`
  : missingSupabaseVariables.length > 0
    ? 'Muniwork setup required'
    : 'Organization section not found | Muniwork';
const pageDescription = organization && section
  ? `${section.body} ${organization.officialName}.`
  : 'Muniwork profiles local government organizations and public-sector career opportunities.';
const canonicalUrl = organization && section && workflow
  ? getCanonicalUrl(Astro.url, `/${organization.slug}/${workflow}`)
  : getCanonicalUrl(Astro.url);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  image={organization?.sealAsset?.publicUrl}
>
  {missingSupabaseVariables.length > 0 ? (
    <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
  ) : section && organization ? (
    <ProfileShell
      organization={organization}
      totalOpenJobs={totalOpenJobs}
      totalOpenBids={totalOpenBids}
    >
      <ProfilePlaceholderSection
        title={section.title}
        label={section.label}
        body={section.body}
        metrics={section.metrics}
      />
    </ProfileShell>
  ) : (
    <ProfileNotFound
      title="Organization section not found"
      body="There is no organization profile section for this URL."
    />
  )}
</BaseLayout>
