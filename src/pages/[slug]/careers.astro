---
export const prerender = false;

import ProfileCareersList from '../../components/profile/ProfileCareersList.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import SupabaseSetupNotice from '../../components/system/SupabaseSetupNotice.astro';
import { getOpenJobsByOrganizationId, getOrganizationBySlug } from '../../lib/organizations.js';
import { MissingSupabaseEnvError } from '../../lib/supabase.js';
import '../../styles/global.css';

type OpenJob = {
  id: string;
  title: string;
  department?: string | null;
  location?: string | null;
  employmentType?: string | null;
  postedAt?: string | null;
  closesAt?: string | null;
  applyUrl?: string | null;
  status: string;
  firstSeenAt?: string | null;
  lastSeenAt?: string | null;
};

const { slug } = Astro.params;
let organization = null;
let openJobs: OpenJob[] = [];
let totalOpenJobs = 0;
let missingSupabaseVariables = [];

try {
  organization = await getOrganizationBySlug(slug);

  if (organization) {
    const jobsResult = await getOpenJobsByOrganizationId(organization.id, { limit: 100 });
    openJobs = jobsResult.jobs;
    totalOpenJobs = jobsResult.total;
  }
} catch (error) {
  if (!(error instanceof MissingSupabaseEnvError)) {
    throw error;
  }

  missingSupabaseVariables = error.missingVariables;
}

if (missingSupabaseVariables.length > 0) {
  Astro.response.status = 503;
} else if (!organization) {
  Astro.response.status = 404;
}
---

{missingSupabaseVariables.length > 0 ? (
  <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
) : organization ? (
  <ProfileShell organization={organization}>
    <ProfileCareersList openJobs={openJobs} totalOpenJobs={totalOpenJobs} />
  </ProfileShell>
) : (
  <main class="min-h-screen bg-muted/30 px-5 py-12 text-foreground">
    <div class="mx-auto max-w-3xl">
      <p class="badge" data-variant="outline">
        Not found
      </p>
      <h1 class="mt-3 text-4xl font-semibold leading-none sm:text-5xl">
        Organization not found
      </h1>
      <p class="mt-3 leading-7 text-muted-foreground">
        There is no organization profile for this slug.
      </p>
    </div>
  </main>
)}
