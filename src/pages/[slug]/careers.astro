---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileCareersList from '../../components/profile/ProfileCareersList.astro';
import ProfileNotFound from '../../components/profile/ProfileNotFound.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import SupabaseSetupNotice from '../../components/system/SupabaseSetupNotice.astro';
import { getProfileRouteStatus, loadProfileRouteData } from '../../lib/profile-route';
import { getCanonicalUrl } from '../../lib/site';
import '../../styles/global.css';

const { slug } = Astro.params;
const routeData = await loadProfileRouteData(slug, { bidLimit: 1, jobLimit: 100 });
const { profile, missingSupabaseVariables } = routeData;
const { organization, openJobs, totalOpenJobs, totalOpenBids } = profile;
const routeStatus = getProfileRouteStatus(routeData);

if (routeStatus) {
  Astro.response.status = routeStatus;
}

const pageTitle = organization
  ? `${organization.officialName} careers | Muniwork`
  : missingSupabaseVariables.length > 0
    ? 'Muniwork setup required'
    : 'Organization careers not found | Muniwork';
const pageDescription = organization
  ? `Open public-sector jobs and career opportunities at ${organization.officialName}.`
  : 'Muniwork profiles local government organizations and public-sector career opportunities.';
const canonicalUrl = organization
  ? getCanonicalUrl(Astro.url, `/${organization.slug}/careers`)
  : getCanonicalUrl(Astro.url);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  image={organization?.sealAsset?.publicUrl}
>
  {missingSupabaseVariables.length > 0 ? (
    <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
  ) : organization ? (
    <ProfileShell
      organization={organization}
      totalOpenJobs={totalOpenJobs}
      totalOpenBids={totalOpenBids}
    >
      <ProfileCareersList
        openJobs={openJobs}
        totalOpenJobs={totalOpenJobs}
        showSectionDivider={false}
        showPostedDates={false}
      />
    </ProfileShell>
  ) : (
    <ProfileNotFound />
  )}
</BaseLayout>
