---
export const prerender = false;

import { ArrowRight } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import SupabaseSetupNotice from '../components/system/SupabaseSetupNotice.astro';
import { loadProfileRouteData } from '../lib/profile-route';
import { getCanonicalUrl } from '../lib/site';
import '../styles/global.css';

const routeData = await loadProfileRouteData('boca-raton-fl', {
  bidLimit: 0,
  jobLimit: 0,
  meetingLimit: 0,
});
const { profile, missingSupabaseVariables } = routeData;
const organization = profile.organization;
const pageTitle = 'Muniwork | Public service work, made visible';
const pageDescription =
  'Muniwork illuminates vital public service work across local government profiles, careers, procurement, meetings, and leadership records.';
const canonicalUrl = getCanonicalUrl(Astro.url, '/');
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  image={organization?.sealAsset?.publicUrl}
>
  <main class="min-h-screen bg-background text-foreground">
    <header class="border-b">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a class="flex items-center gap-3 font-semibold" href="/">
          <span
            class="grid size-9 place-items-center rounded-full border bg-background text-foreground shadow-sm"
            aria-hidden="true"
          >
            <svg
              class="size-6"
              viewBox="0 0 40 40"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M6 28V18C6 14.2 9.1 11 13 11C16.9 11 20 14.2 20 18V28M20 28V18C20 14.2 23.1 11 27 11C30.9 11 34 14.2 34 18V28"
                stroke="currentColor"
                stroke-width="6"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span>muniwork</span>
        </a>
        {organization && (
          <a class="btn gap-2" data-variant="outline" href={`/${organization.slug}`}>
            View profile
            <ArrowRight class="size-4" aria-hidden="true" />
          </a>
        )}
      </div>
    </header>

    {missingSupabaseVariables.length > 0 ? (
      <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
    ) : (
      <section class="mx-auto grid min-h-[calc(100vh-4rem)] max-w-7xl items-center gap-12 px-4 py-12 sm:px-6 lg:grid-cols-[minmax(0,1fr)_25rem] lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-muted-foreground">
            Muniwork
          </p>
          <h1 class="mt-5 max-w-4xl text-5xl font-semibold leading-[1.02] sm:text-6xl lg:text-7xl">
            Illuminating vital public service work.
          </h1>
          <p class="mt-7 max-w-2xl text-lg leading-8 text-muted-foreground">
            Local government profiles for careers, procurement, public meetings, leadership,
            and the operational work that keeps communities moving.
          </p>
          {organization && (
            <div class="mt-9">
              <a class="btn gap-2" href={`/${organization.slug}`}>
                Explore Boca Raton
                <ArrowRight class="size-4" aria-hidden="true" />
              </a>
            </div>
          )}
        </div>

        {organization && (
          <a
            class="group block rounded-lg border bg-card p-6 text-card-foreground shadow-sm transition hover:border-foreground/40"
            href={`/${organization.slug}`}
          >
            <div class="flex items-center gap-5">
              {organization.sealAsset?.publicUrl && (
                <img
                  alt={`${organization.officialName} seal`}
                  class="size-20 rounded-full border bg-background object-contain p-2"
                  height="80"
                  src={organization.sealAsset.publicUrl}
                  width="80"
                />
              )}
              <div class="min-w-0">
                <p class="text-sm font-medium text-muted-foreground">Featured profile</p>
                <h2 class="mt-1 truncate text-2xl font-semibold">{organization.officialName}</h2>
              </div>
            </div>
            <dl class="mt-8 grid grid-cols-2 gap-4 border-t pt-6 text-sm">
              <div>
                <dt class="font-medium">Work surfaces</dt>
                <dd class="mt-1 text-muted-foreground">Careers, bids, meetings</dd>
              </div>
              <div>
                <dt class="font-medium">Location</dt>
                <dd class="mt-1 text-muted-foreground">{organization.stateCode}</dd>
              </div>
            </dl>
            <p class="mt-8 inline-flex items-center gap-2 text-sm font-semibold">
              Open profile
              <ArrowRight
                class="size-4 transition group-hover:translate-x-0.5"
                aria-hidden="true"
              />
            </p>
          </a>
        )}
      </section>
    )}
  </main>
</BaseLayout>
