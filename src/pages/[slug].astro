---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileNotFound from '../components/profile/ProfileNotFound.astro';
import ProfilePage from '../components/profile/ProfilePage.astro';
import SupabaseSetupNotice from '../components/system/SupabaseSetupNotice.astro';
import { getProfileRouteStatus, loadProfileRouteData } from '../lib/profile-route';
import { getCanonicalUrl, getProfileDescription } from '../lib/site';
import '../styles/global.css';

const { slug } = Astro.params;
const routeData = await loadProfileRouteData(slug, { bidLimit: 5, jobLimit: 5 });
const { profile, missingSupabaseVariables } = routeData;
const {
  organization,
  openJobs,
  totalOpenJobs,
  openBids,
  totalOpenBids,
  leadership,
  upcomingMeetings,
  totalUpcomingMeetings,
} = profile;
const routeStatus = getProfileRouteStatus(routeData);

if (routeStatus) {
  Astro.response.status = routeStatus;
}

const pageTitle = organization
  ? `${organization.officialName} | Muniwork`
  : missingSupabaseVariables.length > 0
    ? 'Muniwork setup required'
    : 'Organization not found | Muniwork';
const pageDescription = organization
  ? getProfileDescription(organization)
  : 'Muniwork profiles local government organizations and public-sector career opportunities.';
const canonicalUrl = organization ? getCanonicalUrl(Astro.url, `/${organization.slug}`) : getCanonicalUrl(Astro.url);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  image={organization?.sealAsset?.publicUrl}
>
  {missingSupabaseVariables.length > 0 ? (
    <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
  ) : organization ? (
    <ProfilePage
      organization={organization}
      openJobs={openJobs}
      totalOpenJobs={totalOpenJobs}
      openBids={openBids}
      totalOpenBids={totalOpenBids}
      leadership={leadership}
      upcomingMeetings={upcomingMeetings}
      totalUpcomingMeetings={totalUpcomingMeetings}
    />
  ) : (
    <ProfileNotFound />
  )}
</BaseLayout>
