---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ProfilePage from '../components/profile/ProfilePage.astro';
import SupabaseSetupNotice from '../components/system/SupabaseSetupNotice.astro';
import type { OpenJob } from '../lib/jobs';
import { getOrganizationProfileBySlug } from '../lib/profile';
import { MissingSupabaseEnvError } from '../lib/supabase.js';
import '../styles/global.css';

const { slug } = Astro.params;
let organization = null;
let openJobs: OpenJob[] = [];
let totalOpenJobs = 0;
let missingSupabaseVariables = [];

try {
  const profile = await getOrganizationProfileBySlug(slug, { jobLimit: 5 });
  organization = profile.organization;
  openJobs = profile.openJobs;
  totalOpenJobs = profile.totalOpenJobs;
} catch (error) {
  if (!(error instanceof MissingSupabaseEnvError)) {
    throw error;
  }

  missingSupabaseVariables = error.missingVariables;
}

if (missingSupabaseVariables.length > 0) {
  Astro.response.status = 503;
} else if (!organization) {
  Astro.response.status = 404;
}

const pageTitle = organization
  ? `${organization.officialName} | Muniwork`
  : missingSupabaseVariables.length > 0
    ? 'Muniwork setup required'
    : 'Organization not found | Muniwork';
const pageDescription = organization
  ? `Profile for ${organization.officialName}${organization.stateCode ? ` in ${organization.stateCode}` : ''}, including public-sector career opportunities and organization details.`
  : 'Muniwork profiles local government organizations and public-sector career opportunities.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {missingSupabaseVariables.length > 0 ? (
    <SupabaseSetupNotice missingVariables={missingSupabaseVariables} />
  ) : organization ? (
    <ProfilePage organization={organization} openJobs={openJobs} totalOpenJobs={totalOpenJobs} />
  ) : (
    <main class="min-h-screen bg-muted/30 px-5 py-12 text-foreground">
      <div class="mx-auto max-w-3xl">
        <p class="badge" data-variant="outline">
          Not found
        </p>
        <h1 class="mt-3 text-4xl font-semibold leading-none sm:text-5xl">
          Organization not found
        </h1>
        <p class="mt-3 leading-7 text-muted-foreground">
          There is no organization profile for this slug.
        </p>
      </div>
    </main>
  )}
</BaseLayout>
